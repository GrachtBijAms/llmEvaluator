{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Grounding Cases Schema",
  "description": "Schema for grounding and exact-match evaluator test cases.",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "input_text",
      "expected_output",
      "context",
      "expected_grounding_score"
    ],
    "properties": {
      "id": {
        "type": "string",
        "minLength": 1,
        "description": "Unique identifier for the test case."
      },
      "input_text": {
        "type": "string",
        "minLength": 1,
        "description": "Prompt or user input."
      },
      "expected_output": {
        "type": "string",
        "minLength": 1,
        "description": "Reference answer for exact-match evaluation."
      },
      "actual_output": {
        "type": "string",
        "minLength": 1,
        "description": "Model-generated output being evaluated."
      },
      "category": {
  "type": "string",
  "enum": [    "grounding",
    "exact_match",
    "hallucination",
    "format",
    "insufficient_context",
    "partial_grounding",
    "contradiction",
    "abstention",
    "multi_claim"],
  "description": "Case category used for grouping and filtering."
},

      "context": {
        "type": "array",
        "minItems": 1,
        "description": "Evidence/context used for grounding evaluation.",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "expected_grounding_score": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 1.0,
        "description": "Expected grounding score."
      },
      "expected_exact_match_score": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 1.0,
        "description": "Expected exact match score."
      },
      "expected_overall_passed": {
        "type": "boolean",
        "description": "Expected final pass/fail state."
      },
      "notes": {
        "type": "string",
        "minLength": 1,
        "description": "Short human-readable note about the purpose of the case."
      },
      "why_expected": {
        "type": "string",
        "minLength": 1,
        "description": "Why the expected metric values are correct."
      }
    },
    "additionalProperties": false
  }
}
